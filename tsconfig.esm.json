{
  "compilerOptions": {
    "target": "ES2020", "module": "NodeNext",
    "moduleResolution": "NodeNext", "lib": ["ES2020"],
    "strict": true, "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": false, "outDir": "./dist/esm",
    "rootDir": "./src", "skipLibCheck": true
  },
  "include": ["src"]
}